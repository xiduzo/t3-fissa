{
  "name": "@fissa/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "rm -rf .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "lint": "SKIP_ENV_VALIDATION=1 next lint",
    "lint:fix": "pnpm lint --fix",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
