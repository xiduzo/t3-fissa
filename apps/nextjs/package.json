    "@trpc/client": "^10.38.0",
    "@trpc/next": "^10.38.0",
    "@trpc/react-query": "^10.38.0",
    "@trpc/server": "^10.38.0",
    "next": "^13.3.1",
    "next-auth": "^4.23.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "autoprefixer": "^10.4.15",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.48.0",
    "eslint-config-acme": "0.0.0",
    "postcss": "^8.4.23",
