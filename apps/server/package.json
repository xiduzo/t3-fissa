{
  "name": "@fissa/server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "clean": "rm -rf dist .turbo node_modules",
    "dev": "pnpm with-env tsx watch src/index.ts",
    "start": "node dist/index.mjs",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "type-check": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@fissa/api": "*",
    "@fissa/auth": "*",
    "@fissa/db": "*",
    "@fissa/env": "*",
    "@fissa/utils": "*",
    "@hono/node-server": "^1.13.7",
    "@sentry/node": "^10.48.0",
    "@trpc/server": "11.16.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@fissa/eslint-config": "*",
    "@types/node": "20.12.11",
    "dotenv-cli": "7.4.2",
    "eslint": "8.57.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3"
  }
}