{
  "extends": ["expo/tsconfig.base", "../../tsconfig.json"],
  "compilerOptions": {
    "jsx": "react-native",
    // The root config narrows `types` to ts-reset; restore Node typings so the
    // server packages pulled into the type graph (@fissa/db, @fissa/api) and
    // the build-time expo-plugins resolve `node:*`/`NodeJS.*`.
    "types": ["node", "@total-typescript/ts-reset"]
  },
  "include": [
    "app",
    "expo-plugins",
    "src",
    "app.config.ts",
    "index.js",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}