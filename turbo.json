{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env"
  ],
  "pipeline": {
    "db:generate": {
      "inputs": [
        "schema.ts",
        "drizzle.config.ts"
      ],
      "cache": false
    },
    "db:migrate": {
      "inputs": [
        "drizzle/**"
      ],
      "cache": false
    },
    "db:push": {
      "inputs": [
        "schema.ts",
        "drizzle.config.ts"
      ],
      "cache": false
    },
    "dev": {
      "persistent": false,
      "cache": false
    },
    "dev:ios": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": [
        "^build",
        "^db:generate"
      ],
      "outputs": [
        ".expo/**",
        ".sync/**",
        "dist/**"
      ]
    },
    "lint": {},
    "lint:fix": {},
    "clean": {
      "cache": false
    },
    "test": {
      "dependsOn": [
        "^db:generate"
      ],
      "cache": false
    },
    "//#clean": {
      "cache": false
    },
    "type-check": {
      "dependsOn": [
        "^db:generate"
      ],
      "cache": false
    }
  },
  "globalEnv": [
    "CI",
    "DATABASE_URL",
    "SPOTIFY_CLIENT_ID",
    "SPOTIFY_CLIENT_SECRET",
    "NEXTAUTH_SECRET",
    "NODE_ENV",
    "PORT",
    "SKIP_ENV_VALIDATION",
    "VITE_API_URL",
    "WEB_URL",
    "MIGRATIONS_PATH",
    "SENTRY_DSN_SERVER"
  ]
}